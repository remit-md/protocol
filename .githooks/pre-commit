#!/bin/bash
set -e

echo "=== Pre-commit: remit-protocol ==="

# Build
echo "[1/3] forge build..."
forge build

# Test
echo "[2/3] forge test..."
forge test

# Format check
echo "[3/3] forge fmt --check..."
forge fmt --check

# Anti-shortcut checks on staged Solidity files
STAGED_SOL=$(git diff --cached --name-only --diff-filter=ACM | grep '\.sol$')
if [ -n "$STAGED_SOL" ]; then
    echo "[QA] Anti-shortcut scan..."
    ISSUES=""
    if echo "$STAGED_SOL" | xargs grep -n 'TODO\|FIXME\|HACK\|XXX\|placeholder\|stub' 2>/dev/null; then
        ISSUES="$ISSUES\n  - Found TODO/FIXME/placeholder comments"
    fi
    if echo "$STAGED_SOL" | xargs grep -n '0x0\{40,\}' 2>/dev/null; then
        ISSUES="$ISSUES\n  - Found placeholder zero addresses"
    fi
    if [ -n "$ISSUES" ]; then
        echo ""
        echo "BLOCKED: Anti-shortcut check failed:"
        echo -e "$ISSUES"
        echo ""
        echo "Fix these issues before committing."
        exit 1
    fi
fi
if [ -z "$STAGED_SOL" ]; then
    : # no Solidity files staged, skip scan
fi

echo "=== Pre-commit passed ==="
